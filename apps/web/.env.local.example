# apps/web environment — copy to `.env.local` for local dev.
#
# HOUSE_DB_PATH — filesystem path to the SQLite database the server-side container singleton
# opens (apps/web/src/lib/container.server.ts). This MUST point at the same DB file the
# @house/app persistence stack uses so scenarios/profiles round-trip (RESEARCH A4/A5).
# Optional: defaults to ./house.sqlite (relative to the server process cwd) when unset.
HOUSE_DB_PATH=./house.sqlite
