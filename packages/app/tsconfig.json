{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "types": ["node", "better-sqlite3"],
    "rootDir": "src",
    "outDir": "dist",
    "composite": true
  },
  "references": [{ "path": "../core" }],
  "include": ["src"],
  "exclude": [
    "dist",
    "src/**/*.test.ts",
    "src/**/_lint-fixtures/**"
  ]
}
